@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <a href="account">@context.User.Identity?.Name</a>
                    <form method="post" action="/logout" class="ms-3">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-link p-0">ログアウト</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="login">ログイン</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
