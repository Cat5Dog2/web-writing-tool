ASPNETCORE_ENVIRONMENT=Development

POSTGRES_DB=web_writing_tool
POSTGRES_USER=web_writing_tool
POSTGRES_PASSWORD=change-this-local-db-password
ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=web_writing_tool;Username=web_writing_tool;Password=change-this-local-db-password

AdminSeed__Email=admin@example.test
AdminSeed__Password=change-this-local-admin-password

AiProviders__Gemini__ApiKey=change-me
AiProviders__Gemini__Model=gemini-3.5-flash
AiProviders__Gemini__Region=Japan
AiProviders__Gemini__TimeoutSeconds=120

SearchProviders__DefaultRegion=Japan
SearchProviders__Tavily__ApiKey=change-me
SearchProviders__Tavily__TimeoutSeconds=30
SearchProviders__X__BearerToken=change-me
SearchProviders__X__TimeoutSeconds=30
SearchProviders__X__DefaultMaxResults=100
SearchProviders__X__BulkMaxResults=500
SearchProviders__X__MonthlySafetyLimitPosts=10000
SearchCache__Policy=dev
